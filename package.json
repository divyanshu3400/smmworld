{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "npx pnpm run typecheck && npx pnpm -r --if-present run build",
    "build:libs": "tsc --build",
    "typecheck:libs": "tsc --build",
    "typecheck": "npx pnpm run typecheck:libs && npx pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "build:api": "npx pnpm --filter @workspace/api-server run build",
    "start:api": "node artifacts/api-server/dist/index.mjs",
    "build:frontend": "npx pnpm --filter @workspace/smm-panel run build",
    "start:frontend": "npx serve artifacts/smm-panel/dist/public --single -l $PORT"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "~5.9.3"
  }
}
